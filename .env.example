# StructureEngine — Environment Variables
# Place this file in your clean_project/ folder as .env
# Never commit this file to git (add .env to .gitignore)

# ── Upstox API Credentials (from developer.upstox.com) ──
UPSTOX_API_KEY=4a9f3d1c-9b40-4d5f-9a49-180ab1758479
UPSTOX_API_SECRET=8ghkv987m1

# ── OAuth Redirect URI ──
# Must match EXACTLY what you set in Upstox developer console
# For local:  http://localhost:5000/auth/callback  
# For Railway: https://your-app.railway.app/auth/callback
UPSTOX_REDIRECT_URI=http://localhost:5000/auth/callback

# ── Access Token (auto-managed after first OAuth login) ──
# Leave blank — app fills this automatically via OAuth flow
# Only set manually if you want to bypass OAuth temporarily
UPSTOX_ACCESS_TOKEN=

# ── Database (Railway sets this automatically) ──
# Leave blank for local SQLite
DATABASE_URL=

# ── Telegram (optional — for trade alerts + daily login reminder) ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=